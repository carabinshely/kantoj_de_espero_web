---
import { pageHref } from '@/lib/seo';
interface Props { title: string; body: string; href?: string; label?: string }
const { title, body, href, label } = Astro.props;
---
<section class="cta-band">
  <div><p class="eyebrow">Keep listening</p><h2>{title}</h2><p class="lede">{body}</p></div>
  {href && label && <a class="button accent" href={pageHref(href)}>{label}</a>}
</section>
