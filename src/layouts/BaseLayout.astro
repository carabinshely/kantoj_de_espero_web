---
import { pageHref, siteUrl, languageAlternates, defaultShareImageUrl, DEFAULT_SHARE_IMAGE_WIDTH, DEFAULT_SHARE_IMAGE_HEIGHT } from '@/lib/seo';
import { languages, siteFacts } from '@/lib/site';
import AnalyticsConsent from '@/components/AnalyticsConsent.astro';
import '@/styles/global.css';
import type { Lang } from '@/lib/types';

interface Props {
  title: string;
  description: string;
  path: string;
  lang?: Lang;
  alternatePath?: string;
  jsonLd?: unknown;
}

const { title, description, path, lang = 'en', alternatePath, jsonLd } = Astro.props;
const alternates = alternatePath ? languageAlternates(path, alternatePath) : [{ lang: 'x-default', href: siteUrl('/') }];
const canonical = siteUrl(path);
const shareImageUrl = defaultShareImageUrl();
const fullTitle = title.includes(siteFacts.artistName) ? title : `${title} | ${siteFacts.artistName}`;
const safeJsonLd = jsonLd ? JSON.stringify(jsonLd).replace(/</g, '\\u003c') : null;
const primaryNav = lang === 'eo'
  ? { aria: 'Ĉefa navigado', songs: 'Kantoj', playlists: 'Ludlistoj', licensing: 'Licencado', about: 'Pri ni', privacy: 'Privateco', settings: 'Analitikaj agordoj', skip: 'Salti al enhavo' }
  : { aria: 'Primary navigation', songs: 'Songs', playlists: 'Playlists', licensing: 'Licensing', about: 'About', privacy: 'Privacy', settings: 'Analytics settings', skip: 'Skip to content' };
const langHome = languages[lang].home;
const otherLang: Lang = lang === 'en' ? 'eo' : 'en';
const otherLangHome = languages[otherLang].home;
const privacyHref = lang === 'eo' ? '/eo/privateco/' : '/en/privacy/';
const settingsHref = `${privacyHref}#analytics-settings`;
const navItems = [
  { href: langHome, label: languages[lang].label, active: path === langHome },
  { href: otherLangHome, label: languages[otherLang].label, active: false },
  { href: languages[lang].songs, label: primaryNav.songs, active: path.startsWith(languages[lang].songs) },
  { href: languages[lang].playlists, label: primaryNav.playlists, active: path.startsWith(languages[lang].playlists) },
  { href: languages[lang].licensing, label: primaryNav.licensing, active: path.startsWith(languages[lang].licensing) },
];
---
<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {alternates.map((alt) => <link rel="alternate" hreflang={alt.lang} href={alt.href} />)}
    <meta property="og:type" content="website" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content={siteFacts.artistName} />
    <meta property="og:image" content={shareImageUrl} />
    <meta property="og:image:width" content={String(DEFAULT_SHARE_IMAGE_WIDTH)} />
    <meta property="og:image:height" content={String(DEFAULT_SHARE_IMAGE_HEIGHT)} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={shareImageUrl} />
    {safeJsonLd && <script is:inline type="application/ld+json" set:html={safeJsonLd} />}
  </head>
  <body>
    <a class="skip-link" href="#main">{primaryNav.skip}</a>
    <header class="site-header">
      <a class="brand" href={pageHref("/")}>{siteFacts.artistName}</a>
      <nav aria-label={primaryNav.aria}>
        {navItems.map((item) => <a href={pageHref(item.href)} aria-current={item.active ? 'page' : undefined}>{item.label}</a>)}
      </nav>
    </header>
    <main id="main">
      <slot />
    </main>
    <footer class="site-footer">
      <p>{siteFacts.artistName} — {siteFacts.tagline}</p>
      <p><a href={pageHref(languages[lang].about)}>{primaryNav.about}</a> · <a href={pageHref(languages[lang].licensing)}>{primaryNav.licensing}</a> · <a href={pageHref(privacyHref)}>{primaryNav.privacy}</a> · <a href={pageHref(settingsHref)} data-consent-manage>{primaryNav.settings}</a></p>
    </footer>
    <AnalyticsConsent lang={lang} />
  </body>
</html>
