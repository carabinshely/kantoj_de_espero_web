---
import BaseLayout from '@/layouts/BaseLayout.astro';
import LanguageSwitch from '@/components/LanguageSwitch.astro';
import { musicGroupJsonLd } from '@/lib/seo';
---
<BaseLayout title="About Kantoj de Espero" description="Kantoj de Espero is a modern Esperanto pop-rock project created in 2024 for fresh, shareable Esperanto music." path="/en/about/" alternatePath="/eo/pri-ni/" lang="en" jsonLd={musicGroupJsonLd('/en/about/')}>
  <section class="hero">
    <p class="eyebrow">About</p>
    <h1>A modern Esperanto pop-rock project.</h1>
    <p class="lede">Fresh, contemporary Esperanto songs for listeners, learners, clubs, creators, and music supervisors.</p>
  </section>
  <section class="panel">
    <h2>Public bio</h2>
    <p>Kantoj de Espero is a modern Esperanto pop-rock project created in 2024 to bring fresh, contemporary energy to the Esperanto community. It grew from exploring modern AI music tools and a wish to make Esperanto feel alive, melodic, and easy to share.</p>
  </section>
  <section class="panel">
    <h2>What this site is for</h2>
    <p>The music remains centered on streaming platforms. This website gives listeners and search engines clean bilingual context: song pages, lyrics, playlist framing, and lightweight paths to licensing or custom-song interest.</p>
    <p class="muted">The project is transparent about its modern virtual production context without making production tooling the headline of the music.</p>
  </section>
  <LanguageSwitch href="/eo/pri-ni/" label="Legu pri ni Esperante" />
</BaseLayout>
