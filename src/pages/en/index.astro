---
import { pageHref } from '@/lib/seo'; import BaseLayout from '@/layouts/BaseLayout.astro'; import SongCard from '@/components/SongCard.astro'; import PlaylistCard from '@/components/PlaylistCard.astro'; import CtaBand from '@/components/CtaBand.astro'; import LanguageSwitch from '@/components/LanguageSwitch.astro'; import { songs, playlists } from '@/lib/site'; import { musicGroupJsonLd } from '@/lib/seo';
const featured = songs.filter((song) => song.featured).slice(0, 3); const start = playlists.find((playlist) => playlist.id === 'start-here-modern-esperanto-pop-rock')!;
---
<BaseLayout title="Modern Esperanto Pop-Rock" description="Discover Kantoj de Espero songs, Esperanto lyrics, and a clear first listening path." path="/en/" alternatePath="/eo/" lang="en" jsonLd={musicGroupJsonLd('/en/')}>
<section class="hero"><p class="eyebrow">Modern Esperanto music</p><h1>A first song can open a new language.</h1><p class="lede">Start with a small, human-curated route through songs made to be heard again — with complete Esperanto lyrics whenever you want to stay with the words.</p><div class="actions"><a class="button accent" href={pageHref('/en/playlists/start-here-modern-esperanto-pop-rock/')} data-analytics-event="playlist_cta_click" data-analytics-entity-type="playlist" data-analytics-entity-id={start.id} data-analytics-lang="en">Start Here</a><a class="button" href={pageHref('/en/songs/')}>Browse the catalog</a></div></section>
<LanguageSwitch href="/eo/" label="Legu Esperante" />
<section class="editorial-section"><div class="section-heading"><div><p class="eyebrow">Your first path</p><h2>{start.title_en}</h2></div><p class="lede">{start.intro_en}</p></div><PlaylistCard playlist={start} lang="en" /></section>
<section class="editorial-section"><div class="section-heading"><div><p class="eyebrow">A lyric booklet</p><h2>Read where the music stays with you.</h2></div><p class="lede">Every song page holds its complete Esperanto text, set for reading rather than skimming.</p></div><div class="catalog-list">{featured.map((song, index) => <SongCard song={song} lang="en" index={index + 1} />)}</div></section>
<section class="editorial-section"><div class="section-heading"><h2>More ways in</h2><p class="lede">Five listening paths, each with its own mood and order.</p></div><div class="playlist-stack">{playlists.filter((playlist) => playlist.id !== start.id).map((playlist) => <PlaylistCard playlist={playlist} lang="en" />)}</div></section>
<CtaBand title="Context for listeners and collaborators." body="Learn about the project or ask about licensing without leaving the music behind." href="/en/about/" label="About the project" />
</BaseLayout>
