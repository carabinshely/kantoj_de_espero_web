---
import BaseLayout from '@/layouts/BaseLayout.astro';
import LanguageSwitch from '@/components/LanguageSwitch.astro';
import { songs, siteFacts } from '@/lib/site';
const available = songs.filter((song) => song.license_available);
---
<BaseLayout title="Licensing and Custom Songs" description="Licensing and custom-song inquiries for Kantoj de Espero. Contact the project by email for rights and availability." path="/en/licensing/" alternatePath="/eo/licencado/" lang="en">
  <section class="hero">
    <p class="eyebrow">Licensing</p>
    <h1>Music for Esperanto projects, media, and events.</h1>
    <p class="lede">Selected Kantoj de Espero songs may be available for licensing or custom-song conversations.</p>
  </section>
  <section class="editorial-section panel">
    <h2>Contact</h2>
    <p>Rights and licensing inquiries are handled by Kantoj de Espero.</p>
    <p><a class="button accent contact-link" href={siteFacts.contactMethod}>kantojdeespero@gmail.com</a></p>
  </section>
  <section class="editorial-section panel">
    <h2>Ownership and catalog notes</h2>
    <p>Kantoj de Espero handles rights and licensing questions for the songs and lyrics in this catalog.</p>
    <p class="muted">{available.length} MVP songs are marked as license-available in the public catalog. Support links remain omitted until support details are approved.</p>
  </section>
  <LanguageSwitch href="/eo/licencado/" label="Legu pri licencado Esperante" />
</BaseLayout>
