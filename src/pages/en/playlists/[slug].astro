---
import BaseLayout from '@/layouts/BaseLayout.astro'; import LanguageSwitch from '@/components/LanguageSwitch.astro'; import SongCard from '@/components/SongCard.astro'; import ListeningSurface from '@/components/ListeningSurface.astro'; import { playlists, localizedPlaylist, playlistPath, songsForPlaylist, songPath, playlistMood } from '@/lib/site'; import { playlistJsonLd } from '@/lib/seo';
export function getStaticPaths() { return playlists.map((playlist) => ({ params: { slug: playlist.slug_en }, props: { playlist } })); }
const { playlist } = Astro.props; const copy = localizedPlaylist(playlist, 'en'); const playlistSongs = songsForPlaylist(playlist);
---
<BaseLayout title={copy.seoTitle} description={copy.metaDescription} path={playlistPath(playlist, 'en')} alternatePath={playlistPath(playlist, 'eo')} lang="en" jsonLd={playlistJsonLd(copy.title, copy.metaDescription, playlistPath(playlist, 'en'), playlistSongs.map((song) => songPath(song, 'en')))}><section class="hero"><p class="eyebrow">Playlist / {playlistMood(playlist)}</p><h1>{copy.title}</h1><p class="lede">{copy.intro}</p><ListeningSurface links={playlist.streaming_links} entityType="playlist" entityId={playlist.id} lang="en" explicitLoad /></section><LanguageSwitch href={playlistPath(playlist, 'eo')} label="Legu ĉi tiun ludliston Esperante" /><section class="editorial-section"><div class="section-heading"><h2>Songs, in order</h2><p class="lede">Start here, then follow the sequence into a song page before heading outward to listen.</p></div><div class="catalog-list">{playlistSongs.map((song,index) => <SongCard song={song} lang="en" index={index+1} />)}</div></section></BaseLayout>
