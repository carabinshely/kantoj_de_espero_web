---
import BaseLayout from '@/layouts/BaseLayout.astro'; import PlaylistCard from '@/components/PlaylistCard.astro'; import LanguageSwitch from '@/components/LanguageSwitch.astro'; import { playlists } from '@/lib/site';
---
<BaseLayout title="Esperanto Music Playlists" description="Five editorial Kantoj de Espero listening paths for modern Esperanto music discovery." path="/en/playlists/" alternatePath="/eo/ludlistoj/" lang="en"><section class="hero"><p class="eyebrow">Listening paths</p><h1>Five ways into the catalog.</h1><p class="lede">Choose a mood, follow an order, and let one song lead to the next.</p></section><LanguageSwitch href="/eo/ludlistoj/" label="Vidi ludlistojn Esperante" /><section class="editorial-section"><div class="playlist-stack">{playlists.map((playlist) => <PlaylistCard playlist={playlist} lang="en" />)}</div></section></BaseLayout>
