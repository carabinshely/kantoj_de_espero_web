---
import BaseLayout from '@/layouts/BaseLayout.astro'; import SongCard from '@/components/SongCard.astro'; import LanguageSwitch from '@/components/LanguageSwitch.astro'; import { songs } from '@/lib/site';
---
<BaseLayout title="Esperanto Songs" description="Browse 20 modern Esperanto songs by Kantoj de Espero with complete lyrics and playlist context." path="/en/songs/" alternatePath="/eo/kantoj/" lang="en"><section class="hero"><p class="eyebrow">Catalog</p><h1>Twenty songs, held close.</h1><p class="lede">Esperanto titles and English context sit together here. Choose one to listen, read its complete lyrics, and find its place in the playlists.</p></section><LanguageSwitch href="/eo/kantoj/" label="Vidi la kantindekson Esperante" /><section class="editorial-section"><div class="catalog-list">{songs.map((song,index) => <SongCard song={song} lang="en" index={index+1} />)}</div></section></BaseLayout>
