---
import { pageHref } from '@/lib/seo';
import BaseLayout from '@/layouts/BaseLayout.astro';
import SongCard from '@/components/SongCard.astro';
import PlaylistCard from '@/components/PlaylistCard.astro';
import LanguageSwitch from '@/components/LanguageSwitch.astro';
import { songs, playlists } from '@/lib/site';
import { musicGroupJsonLd } from '@/lib/seo';
const featured = songs.filter((song) => song.featured).slice(0, 6);
---
<BaseLayout title="Modernaj Esperantaj Poprokaj Kantoj" description="Malkovru kantojn, Esperantajn tekstojn kaj temajn ludlistojn de Kantoj de Espero." path="/eo/" alternatePath="/en/" lang="eo" jsonLd={musicGroupJsonLd('/eo/')}>
  <section class="hero">
    <p class="eyebrow">Komencu ĉi tie</p>
    <h1>Modernaj Esperantaj kantoj kun tekstoj kaj ludlistoj.</h1>
    <p class="lede">Esploru unuan kolekton de modernaj Esperantaj kantoj de Kantoj de Espero, organizitan por aŭskultantoj, lernantoj, kluboj, kreantoj kaj muzikaj kunlaboroj.</p>
    <div class="actions"><a class="button accent" href={pageHref("/eo/ludlistoj/komencu-ci-tie-modernaj-esperantaj-poprokaj-kantoj/")}>Komencu per la ludlisto</a><a class="button" href={pageHref("/eo/kantoj/")}>Foliumi kantojn</a></div>
  </section>
  <LanguageSwitch href="/en/" label="Read in English" />
  <section><h2>Elstaraj kantoj</h2><div class="grid">{featured.map((song) => <SongCard song={song} lang="eo" />)}</div></section>
  <section><h2>Ludlistaj vojoj</h2><div class="grid">{playlists.map((playlist) => <PlaylistCard playlist={playlist} lang="eo" />)}</div></section>
</BaseLayout>
