---
import { pageHref } from '@/lib/seo'; import BaseLayout from '@/layouts/BaseLayout.astro'; import SongCard from '@/components/SongCard.astro'; import PlaylistCard from '@/components/PlaylistCard.astro'; import CtaBand from '@/components/CtaBand.astro'; import LanguageSwitch from '@/components/LanguageSwitch.astro'; import { songs, playlists } from '@/lib/site'; import { musicGroupJsonLd } from '@/lib/seo';
const featured = songs.filter((song) => song.featured).slice(0, 3); const start = playlists.find((playlist) => playlist.id === 'start-here-modern-esperanto-pop-rock')!;
---
<BaseLayout title="Modernaj Esperantaj Poprokaj Kantoj" description="Malkovru Kantoj de Espero, Esperantajn tekstojn kaj klaran unuan aŭskultan vojon." path="/eo/" alternatePath="/en/" lang="eo" jsonLd={musicGroupJsonLd('/eo/')}>
<section class="hero"><p class="eyebrow">Moderna Esperanta muziko</p><h1>Unu unua kanto povas malfermi novan lingvon.</h1><p class="lede">Komencu per eta, hom-kuracita vojo tra kantoj faritaj por esti reaŭskultataj — kun kompletaj Esperantaj tekstoj kiam vi volas resti kun la vortoj.</p><div class="actions"><a class="button accent" href={pageHref('/eo/ludlistoj/komencu-ci-tie-modernaj-esperantaj-poprokaj-kantoj/')} data-analytics-event="playlist_cta_click" data-analytics-entity-type="playlist" data-analytics-entity-id={start.id} data-analytics-lang="eo">Komencu ĉi tie</a><a class="button" href={pageHref('/eo/kantoj/')}>Foliumi la katalogon</a></div></section>
<LanguageSwitch href="/en/" label="Read in English" />
<section class="editorial-section"><div class="section-heading"><div><p class="eyebrow">Via unua vojo</p><h2>{start.title_eo}</h2></div><p class="lede">{start.intro_eo_draft}</p></div><PlaylistCard playlist={start} lang="eo" /></section>
<section class="editorial-section"><div class="section-heading"><div><p class="eyebrow">Teksta libreto</p><h2>Legu, kie la muziko restas kun vi.</h2></div><p class="lede">Ĉiu kantopaĝo enhavas sian kompletan Esperantan tekston, aranĝitan por legado.</p></div><div class="catalog-list">{featured.map((song, index) => <SongCard song={song} lang="eo" index={index + 1} />)}</div></section>
<section class="editorial-section"><div class="section-heading"><h2>Pliaj vojoj enen</h2><p class="lede">Kvin aŭskultaj vojoj, ĉiu kun propra etoso kaj ordo.</p></div><div class="playlist-stack">{playlists.filter((playlist) => playlist.id !== start.id).map((playlist) => <PlaylistCard playlist={playlist} lang="eo" />)}</div></section>
<CtaBand title="Kunteksto por aŭskultantoj kaj kunlaborantoj." body="Lernu pri la projekto aŭ demandu pri licencado sen forlasi la muzikon." href="/eo/pri-ni/" label="Pri la projekto" />
</BaseLayout>
