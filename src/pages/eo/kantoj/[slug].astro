---
import BaseLayout from '@/layouts/BaseLayout.astro'; import LanguageSwitch from '@/components/LanguageSwitch.astro'; import TagChips from '@/components/TagChips.astro'; import ListeningSurface from '@/components/ListeningSurface.astro'; import PlaylistCard from '@/components/PlaylistCard.astro'; import { songs, localizedSong, playlistsForSong, songPath } from '@/lib/site'; import { recordingJsonLd } from '@/lib/seo';
export function getStaticPaths() { return songs.map((song) => ({ params: { slug: song.slug }, props: { song } })); }
const { song } = Astro.props; const copy = localizedSong(song, 'eo'); const linkedPlaylists = playlistsForSong(song);
---
<BaseLayout title={copy.title} description={copy.description} path={songPath(song, 'eo')} alternatePath={songPath(song, 'en')} lang="eo" jsonLd={recordingJsonLd(song, songPath(song, 'eo'))}><article class="two-col"><div><p class="eyebrow">Kanto / Esperanta teksto</p><h1>{copy.title}</h1><p class="lede">{copy.hook}</p><ListeningSurface links={song.streaming_links} entityType="song" entityId={song.id} lang="eo" /><LanguageSwitch href={songPath(song, 'en')} label="Read this song in English" /><section class="editorial-section"><p class="eyebrow">Kompleta teksto</p><h2>La vortoj</h2><pre class="lyrics">{song.lyrics_eo}</pre></section></div><aside class="panel"><p class="eyebrow">Kantaj notoj</p><h2>Kunteksto</h2><p>{copy.description}</p><TagChips values={song.public_genres} label="Ĝenroj" /><TagChips values={song.public_moods} label="Etosoj" /><TagChips values={song.public_topics} label="Temoj" />{song.license_available && <p class="meta">Licencado povas esti disponebla por ĉi tiu kanto.</p>}</aside></article><section class="editorial-section"><div class="section-heading"><h2>Aperas en ĉi tiuj vojoj</h2><p class="lede">Daŭrigu per la ludlista kunteksto, kiu alportis ĉi tiun kanton al vi.</p></div><div class="playlist-stack">{linkedPlaylists.map((playlist) => <PlaylistCard playlist={playlist} lang="eo" />)}</div></section></BaseLayout>
