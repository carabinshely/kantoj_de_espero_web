---
import BaseLayout from '@/layouts/BaseLayout.astro'; import SongCard from '@/components/SongCard.astro'; import LanguageSwitch from '@/components/LanguageSwitch.astro'; import { songs } from '@/lib/site';
---
<BaseLayout title="Esperantaj Kantoj" description="Foliumu 20 modernajn Esperantajn kantojn de Kantoj de Espero kun kompletaj tekstoj kaj ludlista kunteksto." path="/eo/kantoj/" alternatePath="/en/songs/" lang="eo"><section class="hero"><p class="eyebrow">Katalogo</p><h1>Dudek kantoj, proksime gardataj.</h1><p class="lede">Esperantaj titoloj kaj angla kunteksto sidas kune ĉi tie. Elektu unu por aŭskulti, legu ĝian kompletan tekston kaj trovu ĝian lokon en la ludlistoj.</p></section><LanguageSwitch href="/en/songs/" label="View the song index in English" /><section class="editorial-section"><div class="catalog-list">{songs.map((song,index) => <SongCard song={song} lang="eo" index={index+1} />)}</div></section></BaseLayout>
