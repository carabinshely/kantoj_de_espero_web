---
import BaseLayout from '@/layouts/BaseLayout.astro'; import PlaylistCard from '@/components/PlaylistCard.astro'; import LanguageSwitch from '@/components/LanguageSwitch.astro'; import { playlists } from '@/lib/site';
---
<BaseLayout title="Esperantaj Muzikaj Ludlistoj" description="Kvin redakciaj aŭskultaj vojoj de Kantoj de Espero por malkovri modernan Esperantan muzikon." path="/eo/ludlistoj/" alternatePath="/en/playlists/" lang="eo"><section class="hero"><p class="eyebrow">Aŭskultaj vojoj</p><h1>Kvin vojoj en la katalogon.</h1><p class="lede">Elektu etoson, sekvu ordon, kaj lasu unu kanton konduki al la sekva.</p></section><LanguageSwitch href="/en/playlists/" label="View playlists in English" /><section class="editorial-section"><div class="playlist-stack">{playlists.map((playlist) => <PlaylistCard playlist={playlist} lang="eo" />)}</div></section></BaseLayout>
