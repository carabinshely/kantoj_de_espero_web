---
import BaseLayout from '@/layouts/BaseLayout.astro';
import LanguageSwitch from '@/components/LanguageSwitch.astro';
import { musicGroupJsonLd } from '@/lib/seo';
---
<BaseLayout title="Pri Kantoj de Espero" description="Kantoj de Espero estas moderna Esperanta muzika projekto kun poprokaj kantoj, tekstoj kaj temaj ludlistoj." path="/eo/pri-ni/" alternatePath="/en/about/" lang="eo" jsonLd={musicGroupJsonLd('/eo/pri-ni/')}>
  <section class="hero"><p class="eyebrow">Pri ni</p><h1>Moderna Esperanta muzika projekto.</h1><p class="lede">Kantoj de Espero prezentas originalajn Esperantajn kantojn kun publikaj tekstoj, temaj ludlistoj kaj kunteksto por aŭskultantoj kiuj malkovras la lingvon per muziko.</p></section>
  <LanguageSwitch href="/en/about/" label="Read about us in English" />
  <section class="panel"><h2>Por kio ekzistas ĉi tiu retejo</h2><p>La muziko restas centrita sur aŭskultaj platformoj. Ĉi tiu retejo donas klaran dulingvan kuntekston: kantopaĝoj, tekstoj, ludlistaj klarigoj kaj malpezaj vojoj al licencado aŭ specialaj kantoj.</p></section>
</BaseLayout>
