---
import { pageHref } from '@/lib/seo';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { musicGroupJsonLd } from '@/lib/seo';
---
<BaseLayout title="Kantoj de Espero" description="Modern Esperanto songs, lyrics, and listening paths in English and Esperanto." path="/" jsonLd={musicGroupJsonLd('/')}>
  <section class="hero"><p class="eyebrow">A bilingual music journal</p><h1>Find a song worth keeping.</h1><p class="lede">Kantoj de Espero is a warm place to begin with modern Esperanto music: listen, read, and follow a small curated path.</p><div class="actions"><a class="button accent" href={pageHref('/en/')}>Enter in English</a><a class="button" href={pageHref('/eo/')}>Eniru Esperante</a></div></section>
</BaseLayout>
